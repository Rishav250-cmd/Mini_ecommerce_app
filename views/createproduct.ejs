<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white">
    <% if(success && success.length > 0){ %>
    <div class="flash-message absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-green-500">
        <span class="inline-block mt-1 mb-1 text-white">
            <%= success %>
        </span>
    </div>
    <% } %>

    <!-- Top bar -->
    <div class="bg-black text-white px-6 py-4">
        <h1 class="text-xl font-semibold">Scatch</h1>
    </div>

    <div class="flex">

        <!-- Sidebar -->
        <aside class="w-64 border-r border-gray-200 min-h-screen py-6 px-6">
            <ul class="space-y-4">
                <li>
                    <a href="/views/admin.ejs" class="text-gray-800 hover:text-blue-600">All Products</a>
                </li>
                <li>
                    <a href="/owners/create-product" class="text-gray-800 hover:text-blue-600">Create new product</a>
                </li>
            </ul>
        </aside>

        <!-- Main content -->
        <main class="flex-1 px-10 py-8">
            <h2 class="text-2xl font-bold mb-6">Create New Product</h2>

            <form action="/products/create" method="POST" enctype="multipart/form-data" class="max-w-3xl">

                <!-- Product Details -->
                <h3 class="text-lg font-bold mb-3">Product Details</h3>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Product Image</label>
                    <input
                        type="file"
                        name="image"
                        accept="image/*"
                        class="text-sm text-gray-600 border border-gray-300 rounded-md file:mr-4 file:py-2 file:px-4 file:border-0 file:bg-gray-100 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200"
                    >
                </div>

                <div class="grid grid-cols-2 gap-4 mb-4">
                    <input
                        type="text"
                        name="name"
                        placeholder="Product Name"
                        class="w-full border border-gray-300 rounded-md px-4 py-3 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >
                    <input
                        type="number"
                        name="price"
                        placeholder="Product Price"
                        class="w-full border border-gray-300 rounded-md px-4 py-3 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >
                </div>

                <div class="grid grid-cols-2 gap-4 mb-8">
                    <input
                        type="number"
                        name="discount"
                        placeholder="Discount Price"
                        class="w-full border border-gray-300 rounded-md px-4 py-3 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >
                </div>

                <!-- Panel Details -->
                <h3 class="text-lg font-bold mb-3">Panel Details</h3>

                <div class="grid grid-cols-2 gap-4 mb-4">
                    <input
                        type="text"
                        name="bgcolor"
                        placeholder="Background Color"
                        class="w-full border border-gray-300 rounded-md px-4 py-3 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >
                    <input
                        type="text"
                        name="panelcolor"
                        placeholder="Panel Color"
                        class="w-full border border-gray-300 rounded-md px-4 py-3 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <input
                        type="text"
                        name="textcolor"
                        placeholder="Text Color"
                        class="w-full border border-gray-300 rounded-md px-4 py-3 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >
                </div>

                <button
                    type="submit"
                    class="bg-blue-500 hover:bg-blue-600 text-white font-medium px-6 py-3 rounded-md transition-colors"
                >
                    Create New Product
                </button>

            </form>
        </main>
    </div>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    const flashMessages = document.querySelectorAll('.flash-message');
    flashMessages.forEach(msg => {
      setTimeout(() => {
        msg.style.transition = 'opacity 0.5s ease';
        msg.style.opacity = '0';
        setTimeout(() => msg.remove(), 500); 
      }, 4000);
    });
  });
</script>
</body>
</html>