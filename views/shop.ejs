<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scatch</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css">
</head>
<body>

  <nav class="flex items-center justify-between px-20 py-4">
    <h1 class="text-3xl px-4 py-2 rounded-md">Scatch</h1>
    <div class="flex gap-5 items-center">
      <a href="/shop">Shop</a>
      <a href="/cart">Cart</a>
      <a href="/account">My Account</a>
      <a href="/logout" class="text-red-500 hover:text-red-600">Logout</a>
    </div>
  </nav>
  <div class="w-full h-screen flex items-start px-20 py-20">
    <div class="w-[25%] flex h-screen flex-col items-start">
      <div class="flex items-center gap-2">
        <h3>sort by</h3>
        <form action="/shop">
          <select class="border-[1px] px-2 py-1" name="sortby" id="">
            <option value="popular">Popular</option>
            <option value="newest">Newest</option>
          </select>
        </form>
      </div>
      <div class="flex flex-col mt-20">
        <a class="block w-fit mb-2" href="">New Collection</a>
        <a class="block w-fit mb-2" href="">All Products</a>
        <a class="block w-fit mb-2" href="">Discounted Products</a>
      </div>
      <div class="mt-32">
        <a class="block w-fit mb-2" href="">Filter by :</a>
        <a class="block w-fit mb-2" href="">Availability</a>
        <a class="block w-fit mb-2" href="">Discount</a>
      </div>
    </div>

    <div class="w-[75%] flex flex-col gap-5 h-screen">
      <div class="flex items-start gap-5">
        <% products.forEach(function(product){ %>
          <div class="w-60">
            <div class="w-full h-52 flex items-center justify-center" style="background-color: <%= product.bgcolor || '#e5e5e5' %>;">
              <img class="h-[12rem]" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
            </div>
            <div
              class="flex justify-between bg-[<%= product.panelcolor || '#f87171' %>] text-[<%= product.textcolor || '#000000' %>] px-4 py-2 rounded-md"
            >
              <div>
                <h3>
                  <%= product.name %>
                </h3>
                <h4>₹ <%= product.price %></h4>
              </div>
              <a class="w-7 h-7 flex items-center justify-center rounded-full bg-white text-black text-xl leading-none font-normal" href="/addtocart/<%= product._id %>">+</a>
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

</body>
</html>